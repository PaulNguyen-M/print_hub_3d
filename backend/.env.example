# ─── Backend environment variables (Print Hub 3D) ───
# Copy thành biến môi trường thật khi deploy. KHÔNG commit giá trị thật.
# Local dev có thể bỏ trống (application.properties đã có default).

# Database
DB_URL=jdbc:postgresql://localhost:5433/print3d_db
DB_USERNAME=postgres
DB_PASSWORD=change-me

# JWT — production BẮT BUỘC đổi thành chuỗi ngẫu nhiên >= 32 ký tự
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS (origin của frontend, cách nhau bằng dấu phẩy)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Stripe (tuỳ chọn — để trống sẽ chạy chế độ thanh toán mock)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
